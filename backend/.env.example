# =========================
# Application
# =========================
# API settings (if applicable)
ENV=local

# =========================
# Database Configuration
# =========================
# Main application database (used by API and ingest)
APP_DB_HOST=db
APP_DB_NAME=app
APP_DB_USERNAME=app_user
APP_DB_PASSWORD=app_pass
APP_DB_PORT=5432
APP_DB_SSLMODE=disable

# Development / shadow database (required for Atlas schema management)
APP_ATLAS_DEV_DB_HOST=db_dev
APP_ATLAS_DEV_DB_NAME=app
APP_ATLAS_DEV_DB_USERNAME=app_user
APP_ATLAS_DEV_DB_PASSWORD=app_pass
APP_ATLAS_DEV_DB_PORT=5432
APP_ATLAS_DEV_DB_SSLMODE=disable

# =========================
# OpenAI Configuration
# =========================
# Required for embeddings and LLM responses
OPENAI_API_KEY=your_api_key_here