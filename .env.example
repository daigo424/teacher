# =========================
# Application
# =========================
# API settings (if applicable)
ENV=local

# =========================
# Database Configuration
# =========================
# Main application database (used by API and ingest)
APP_DB_URL=postgresql://app_user:app_pass@db:5432/app_db?sslmode=disable

# Development / shadow database (required for Atlas schema management)
APP_DEV_DB_URL=postgresql://app_user:app_pass@db_dev:5432/app_db?sslmode=disable

# =========================
# OpenAI Configuration
# =========================
# Required for embeddings and LLM responses
OPENAI_API_KEY=your_api_key_here